# Copy to .env and adjust as needed. All values have working defaults.

# --- App ---
APP_NAME=Payye
DEBUG=true

# --- Security ---
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Database ---
# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./payye.db
# Postgres example:
# DATABASE_URL=postgresql+psycopg://payye:payye@localhost:5432/payye

# --- CORS (comma separated, or * for all) ---
CORS_ORIGINS=*

# --- Storage ---
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./storage
# For MinIO / S3 set STORAGE_BACKEND=s3 and the values below:
# S3_ENDPOINT_URL=http://localhost:9000
# S3_BUCKET=payye
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1

# --- AI (optional; without a key the app uses local heuristics) ---
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
