{
  "expo": {
    "name": "Payye",
    "slug": "payye",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "payye",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiUrl": "http://localhost:8000"
    }
  }
}
