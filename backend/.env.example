# Copy to .env and adjust. Every value has a working default.

# --- App ---
APP_NAME=Payye AI
DEBUG=true

# --- CORS (comma separated, or * for all) ---
CORS_ORIGINS=*

# --- Gateway protection (optional) ---
# If set, the app must send the same value in the X-App-Token header.
# This protects your OpenAI quota; it is NOT user authentication.
# APP_TOKEN=some-shared-secret

# --- Abuse guards ---
RATE_LIMIT_PER_MINUTE=60
MAX_INPUT_CHARS=50000

# --- AI (optional; without a key the app uses local heuristics) ---
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
